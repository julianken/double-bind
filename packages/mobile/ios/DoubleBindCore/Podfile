# Podfile for DoubleBindCore development
# This is used for local development and testing of the pod.
# The actual React Native app will have its own Podfile.

platform :ios, '15.0'

target 'DoubleBindCore' do
  use_frameworks!

  # React Native dependencies
  # In a real React Native app, these would be included via the main Podfile
  # For development/testing of this module, we can keep this minimal
end

# Post-install hook for Xcode configuration
post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      # Set deployment target for all pods
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'

      # Enable module stability for Swift
      config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
    end
  end
end
