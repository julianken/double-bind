{
  "name": "@double-bind/mobile",
  "version": "0.0.1",
  "private": true,
  "description": "Mobile platform implementations for Double-Bind",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:android": "cd android && ./gradlew build",
    "test:android": "cd android && ./gradlew test",
    "clean": "rm -rf dist",
    "clean:android": "cd android && ./gradlew clean",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "double-bind",
    "mobile",
    "android",
    "ios",
    "cozodb"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@double-bind/types": "workspace:*",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "react-native": "^0.73.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "react-native": ">=0.70.0"
  }
}
