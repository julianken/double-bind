{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "settings-window",
  "description": "Capabilities for the settings window",
  "windows": ["settings"],
  "permissions": [
    "core:default",
    "core:window:default",
    {
      "identifier": "core:window:allow-set-title",
      "allow": [{ "label": "settings" }]
    }
  ]
}
