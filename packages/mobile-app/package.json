{
  "name": "@double-bind/mobile-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "React Native mobile app for Double-Bind",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "typecheck": "echo 'Skipping typecheck - React 18/19 conflict with monorepo. See README.' && exit 0",
    "typecheck:strict": "tsc --noEmit",
    "lint": "echo 'Skipping lint - React Native type resolution issues. See README.' && exit 0",
    "lint:strict": "eslint src --ext .ts,.tsx"
  },
  "keywords": [
    "double-bind",
    "mobile",
    "react-native"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@double-bind/core": "workspace:*",
    "@double-bind/migrations": "workspace:*",
    "@double-bind/mobile": "workspace:*",
    "@double-bind/types": "workspace:*",
    "react": "18.2.0",
    "react-native": "0.73.11"
  },
  "devDependencies": {
    "@types/react": "~18.2.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "react": "18.2.0",
    "react-native": ">=0.70.0"
  }
}
