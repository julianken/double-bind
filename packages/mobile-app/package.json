{
  "name": "@double-bind/mobile-app",
  "version": "0.0.1",
  "private": true,
  "description": "Double-Bind React Native mobile application",
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "cd ios && xcodebuild -workspace MobileApp.xcworkspace -scheme MobileApp -configuration Release -sdk iphoneos -archivePath build/MobileApp.xcarchive archive",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "react-native clean"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-native": "0.76.9"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/runtime": "^7.25.0",
    "@react-native/babel-preset": "0.76.9",
    "@react-native/eslint-config": "0.76.9",
    "@react-native/metro-config": "0.76.9",
    "@react-native/typescript-config": "0.76.9",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.0",
    "@types/react-test-renderer": "^18.3.0",
    "@testing-library/react-native": "^12.4.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "react-test-renderer": "18.3.1",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
