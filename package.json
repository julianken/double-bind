{
  "name": "double-bind",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r --sort build",
    "build:desktop": "pnpm --filter=@double-bind/desktop build",
    "dev": "pnpm --filter=@double-bind/desktop dev",
    "dev:desktop": "pnpm --filter=@double-bind/desktop tauri:dev",
    "test": "vitest run --workspace",
    "test:watch": "vitest --workspace",
    "test:unit": "pnpm -r test:unit",
    "test:integration": "vitest run --workspace --project core-integration",
    "test:e2e": "pnpm --filter=@double-bind/desktop test:e2e",
    "test:e2e:full": "pnpm --filter=@double-bind/desktop test:e2e:full",
    "test:e2e:summary": "node scripts/test-summary.js",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.0.0",
    "globals": "^17.3.0",
    "prettier": "^3.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.54.0",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
